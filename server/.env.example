# Copy this file to .env for local development and fill in real values.
# In production (Render), set these as environment variables in the
# service dashboard instead of committing a .env file.

NODE_ENV=development
PORT=8080

# Where your deployed frontend lives. Used for CORS and for redirecting
# the browser back after OAuth / GitHub App install flows.
# Local dev default matches `npm run dev` in /web (Vite).
WEB_ORIGIN=http://localhost:5173

# Where THIS server is reachable from the internet. GitHub OAuth and
# the GitHub App callback URLs are built from this. Must be a real
# public HTTPS URL once deployed — GitHub will not call back to
# localhost.
API_ORIGIN=http://localhost:8080

# Neon Postgres connection string (free tier, no card required).
# Get this from https://neon.tech after creating a project.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Any long random string — used to sign nothing cryptographically right
# now (sessions are opaque DB-backed ids), but reserved for future use
# and required so a deploy can't accidentally run with an empty secret.
SESSION_SECRET=replace-with-a-long-random-string

# --- "Login with GitHub" OAuth App ---
# Create at https://github.com/settings/developers -> "New OAuth App"
# Homepage URL: your WEB_ORIGIN
# Authorization callback URL: <API_ORIGIN>/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- GitHub App (repo access + webhooks) ---
# Create at https://github.com/settings/apps -> "New GitHub App"
# Webhook URL: <API_ORIGIN>/webhooks/github
# Webhook secret: any random string, must match GITHUB_APP_WEBHOOK_SECRET below
# Permissions needed: Issues (read/write), Pull requests (read/write), Metadata (read)
# Subscribe to events: Issues, Pull request, Push
# Where can this GitHub App be installed: Any account
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMII...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_APP_WEBHOOK_SECRET=
# The "slug" is the URL-friendly name of your app, e.g. for
# https://github.com/apps/my-cool-bot the slug is "my-cool-bot"
GITHUB_APP_SLUG=

# --- Slack ---
# Create a Slack App at https://api.slack.com/apps -> "From scratch"
# Enable "Incoming Webhooks" -> "Add New Webhook to Workspace" -> pick a channel
# Paste the generated URL below.
SLACK_WEBHOOK_URL=

# --- AI triage (optional stretch goal) ---
# Free key from https://aistudio.google.com/app/apikey (Google AI Studio).
# Leave blank to disable the AI step entirely — the app works fine without it.
GEMINI_API_KEY=
